{
  "customizations": {
    "vscode": {
      "extensions": ["esbenp.prettier-vscode", "ms-azuretools.vscode-bicep"],
      "settings": {
        "[json]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[jsonc]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[yaml]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "adoCodespacesAuth.tenantID": "e09734be-ca09-41ec-b70d-98f5536fb774",
        "extensions.allowed": {
          "esbenp.prettier-vscode": "stable",
          "github": "stable",
          "microsoft": "stable"
        },
        "git.autofetch": true
      }
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "bicepVersion": "latest",
      "installBicep": true,
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/powershell:2": {
      "version": "latest"
    },
    "ghcr.io/microsoft/codespace-features/external-repository:4": {
      "branch": "main",
      "clientID": "dceac86e-172a-4779-b914-d983ca431c21",
      "cloneUrl": "https://dev.azure.com/byteterrace/Koholint/_git/Azure.Resources",
      "folder": "/workspaces/azdo-repos",
      "gitProvider": "azuredevops",
      "tenantID": "e09734be-ca09-41ec-b70d-98f5536fb774"
    }
  },
  "image": "mcr.microsoft.com/devcontainers/dotnet:10.0",
  "name": "ByteTerrace.Azure.Resources",
  "onCreateCommand": "external-git clone",
  "postStartCommand": "external-git config",
  "workspaceFolder": "/workspaces/azdo-repos",
  "workspaceMount": "source=${localWorkspaceFolder}/../azdo-repos,target=/workspaces/azdo-repos,type=bind"
}
