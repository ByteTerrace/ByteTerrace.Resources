{
  "customizations": {
    "vscode": {
      "extensions": ["esbenp.prettier-vscode", "ms-azuretools.vscode-bicep"],
      "settings": {
        "[json]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[jsonc]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[yaml]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "adoCodespacesAuth.tenantID": "e09734be-ca09-41ec-b70d-98f5536fb774",
        "extensions.allowed": {
          "esbenp.prettier-vscode": "stable",
          "github": "stable",
          "microsoft": "stable"
        },
        "git.autofetch": true
      }
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "bicepVersion": "latest",
      "installBicep": true,
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/powershell:2": {
      "version": "latest"
    }
  },
  "image": "mcr.microsoft.com/devcontainers/dotnet:10.0",
  "name": "ByteTerrace.Azure.Resources",
  "workspaceFolder": "/workspaces"
}
